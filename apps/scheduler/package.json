  "dependencies": {
    "@egi/database": "*",
    "@egi/logging": "*",
    "@egi/queue": "*",
    "@egi/shared-types": "*",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "tsx": "^4.20.3"
  }
}
