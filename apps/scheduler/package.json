{
  "name": "@egi/scheduler",
  "version": "0.1.0",
  "private": true,
  "description": "EGI Website Monitoring job scheduler (BullMQ)",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "test": "tsx --test src/scheduling.test.ts src/scheduler-lock.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
