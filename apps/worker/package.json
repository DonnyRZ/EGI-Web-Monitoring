{
  "name": "@egi/worker",
  "version": "0.1.0",
  "private": true,
  "description": "EGI Website Monitoring worker (HTTP + Playwright + notifications)",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "postinstall": "playwright install chromium",
    "playwright:install": "playwright install chromium",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"@egi/worker: no lint configured yet\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.848.0",
    "@aws-sdk/s3-request-presigner": "^3.848.0",
    "@egi/database": "*",
    "@egi/monitoring-rules": "*",
    "@egi/queue": "*",
    "@egi/shared-types": "*",
    "bullmq": "^5.56.1",
    "dotenv": "^16.6.1",
    "ioredis": "^5.6.1",
    "nodemailer": "^7.0.5",
    "playwright": "^1.54.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
