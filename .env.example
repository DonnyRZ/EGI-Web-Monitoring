# Application
NODE_ENV=development

# Backend API
BACKEND_PORT=3001
API_PREFIX=api

# Frontend
FRONTEND_PORT=3010
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/api

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=egi_monitoring
POSTGRES_USER=egi
POSTGRES_PASSWORD=change_me_postgres
DATABASE_URL=postgresql://egi:change_me_postgres@localhost:5433/egi_monitoring?schema=public

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Required when NODE_ENV=production; leave empty only for private local development.
REDIS_DB=0

# Object storage (S3 / MinIO) — private bucket; API returns short-lived signed URLs
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
# Required when NODE_ENV=production; replace both defaults with strong secrets.
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_minio
S3_BUCKET=egi-monitoring
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_EXPIRES_SEC=900

# Auth
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Comma-separated public frontend origins; mandatory when NODE_ENV=production.
CORS_ORIGINS=http://localhost:3010
# Disabled by default when NODE_ENV=production; set true only for controlled access.
ENABLE_SWAGGER=true

# SMTP (email notifications) — leave SMTP_HOST empty to skip sends (notification → failed)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@egi.co.id

# Telegram Bot API (https://core.telegram.org/bots/api)
# Outbound alerts use sendMessage to chat_id. Leave TELEGRAM_BOT_TOKEN empty to skip
# (notification marked failed — never faked as sent). See apps/worker/TELEGRAM.md
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Monitoring scheduler / worker
MONITORING_INTERVAL_MINUTES=5
SCHEDULER_TICK_SECONDS=15
HTTP_TIMEOUT_MS=15000
BROWSER_TIMEOUT_MS=45000
WORKER_CONCURRENCY=5
# Optional on Windows when Playwright's Headless Shell is blocked by endpoint security.
# Example: C:\\ms-playwright\\chromium-<revision>\\chrome-win64\\chrome.exe
PLAYWRIGHT_EXECUTABLE_PATH=
JOB_MAX_ATTEMPTS=3
LATE_JOB_SKIP_MS=240000

# Data retention (worker daily cron; incidents/tickets kept forever)
RETENTION_CRON=0 2 * * *
RETENTION_MONITORING_RESULTS_DAYS=90
RETENTION_SCREENSHOTS_DAYS=1
RETENTION_NOTIFICATIONS_DAYS=90
