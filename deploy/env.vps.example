NODE_ENV=production
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=egi_monitoring
DB_USER=egi_monitoring
DB_PASSWORD=replace-with-a-strong-unique-password
REDIS_PASSWORD=replace-with-a-strong-unique-password
REDIS_DB=0
S3_REGION=us-east-1
S3_ACCESS_KEY=replace-with-a-strong-access-key
S3_SECRET_KEY=replace-with-a-strong-secret-key
S3_BUCKET=egi-monitoring
S3_PUBLIC_ENDPOINT=https://internal.egiresources.com
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_EXPIRES_SEC=900
JWT_ACCESS_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=https://internal.egiresources.com
ENABLE_SWAGGER=false
SCHEDULER_TICK_SECONDS=15
MONITORING_INTERVAL_MINUTES=5
HTTP_TIMEOUT_MS=15000
BROWSER_TIMEOUT_MS=45000
WORKER_CONCURRENCY=5
JOB_MAX_ATTEMPTS=3
LATE_JOB_SKIP_MS=240000
RETENTION_CRON=0 2 * * *
RETENTION_MONITORING_RESULTS_DAYS=90
RETENTION_SCREENSHOTS_DAYS=1
RETENTION_NOTIFICATIONS_DAYS=90
